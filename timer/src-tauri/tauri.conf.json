{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimerApp",
  "version": "0.1.1",
  "identifier": "com.admin.timer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TimerApp",
        "width": 420,
        "height": 720,
        "resizable": false,
        "maximizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "windows": {
      "wix": {
        "language": {
          "zh-CN": {
            "localePath": "./wix/locales/zh-CN.wxl"
          }
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
