# TimerApp 激活模块本地构建密钥（示例模板）
# 用法：复制到 config/local/activation.env 并修改值，切勿提交 config/local/
#
# 生成 32 字节随机密钥（PowerShell）：
#   -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
#
# 生成 32 字节随机密钥（bash）：
#   openssl rand -hex 32

# HMAC 签名密钥（64 位十六进制，对应 32 字节）
TIMER_ACTIVATION_SECRET_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# 生成器口令：编译期必填；仅 activation-admin 应用内入口校验（release 包不含该入口）
TIMER_GENERATOR_PASSWORD=change-me-before-release
